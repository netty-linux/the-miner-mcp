# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
# Public URL for MCP icon (auto-set on Railway via RAILWAY_PUBLIC_DOMAIN)
PUBLIC_BASE_URL=https://the-miner-mcp-production.up.railway.app

# Optional API keys — tools degrade gracefully when not set
YOUTUBE_API_KEY=your_youtube_data_api_v3_key
FACEBOOK_ACCESS_TOKEN=your_facebook_graph_api_token
TIKTOK_ACCESS_TOKEN=your_tiktok_business_api_token
GOOGLE_API_KEY=your_google_api_key
SERP_API_KEY=your_serpapi_key

# Reddit Data API — use web app + refresh token (recommended) OR script app + password
# Create app: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_REDIRECT_URI=http://localhost:8080
# Web app: run `npm run reddit:setup` once, then paste the refresh token here
REDDIT_REFRESH_TOKEN=
# Script app only (password grant — web apps cannot use this)
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_account_password
# Required format: platform:app_id:version (by /u/username)
REDDIT_USER_AGENT=TheMinerMCP:1.0.0 (by /u/your_username)

# Future authentication (optional)
# When set, clients must send: Authorization: Bearer <token>
# or header: X-MCP-Token: <token>
MCP_AUTH_TOKEN=